{
  "name": "ai-girlfriend",
  "version": "1.0.0",
  "productName": "AI女友",
  "description": "多平台智能陪伴机器人",
  "main": "electron.js",
  "scripts": {
    "test": "jest --verbose",
    "start": "ts-node src/index.ts",
    "start:web": "ts-node src/index.ts",
    "dev": "electron .",
    "start:gui": "electron .",
    "build": "tsc",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:all": "npm run build && electron-builder --win --mac"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.2",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/qrcode-terminal": "^0.12.2",
    "async-mutex": "^0.5.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "ml-distance": "^4.0.1",
    "multer": "^2.0.2",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.10.0",
    "qrcode-terminal": "^0.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wechaty": "^1.20.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.2.0",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  },
  "build": {
    "appId": "com.aigirlfriend.app",
    "productName": "AI女友",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "electron.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI女友"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "Network"
    }
  }
}